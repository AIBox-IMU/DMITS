// 更新节点、边和文本的位置
function ticked() {

    node.attr("transform", d => `translate(${d.x},${d.y})`);
    // 更新线的路径
    linkPath.attr("d", d => {
        return `M${d.source.x},${d.source.y}L${d.target.x},${d.target.y}`;
    });
    linkGroup.attr("transform", d => {
        const dx = d.target.x - d.source.x;
        const dy = d.target.y - d.source.y;
        const x = (d.source.x + d.target.x) / 2;
        const y = (d.source.y + d.target.y) / 2;
        return `translate(${x},${y}) rotate(${Math.atan2(dy, dx) * 180 / Math.PI})`;
    });
    linkRect.each(function (d) {
        const bbox = this.getBBox();
        const padding = 10;
        const text = d3.select(this.parentNode).select(".link-text").node();
        const textWidth = text ? text.getBBox().width : 0;
        const textHeight = text ? text.getBBox().height : 0;
        d3.select(this)
            .attr("width", textWidth + padding)
            .attr("height", bbox.height)
            .attr("x", -textWidth / 2 - padding / 2)
            .attr("y", -bbox.height / 2 + padding / 32);
        if (text) {
            d3.select(text)
                .attr("x", -textWidth / 2)
                .attr("y", textHeight / 64 + 2); // 调整文本的垂直位置为矩形框的64分之一处
        }
    });
}

// 定义拖动行为
function drag(simulation) {

    // 开始拖动
    function dragstarted(event) {
        if (!event.active) simulation.alphaTarget(0.3).restart();
        event.subject.fx = event.subject.x;
        event.subject.fy = event.subject.y;

    }
    // 拖动中
    function dragged(event) {
        event.subject.fx = event.x;
        event.subject.fy = event.y;
        // d3.select(this)
        //     .attr("x", event.subject.fx)
        //     .attr("y", event.subject.fy);

    }

    // 结束拖动
    function dragended(event) {
        if (!event.active) simulation.alphaTarget(0);
        event.subject.fx = event.x;
        event.subject.fy = event.y;

    }

    return d3.drag()
        .on("start", dragstarted)
        .on("drag", dragged)
        .on("end", dragended);
}

