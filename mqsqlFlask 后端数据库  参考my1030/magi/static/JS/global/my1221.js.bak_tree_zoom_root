let nodes, links,nodeIds;
$.ajax({
  url: '/api/graph',
  dataType: 'json',
  async: false,
  success: function(data) {
    if (data && data.data) {
      nodes = data.data.nodes;
      links = data.data.links;
    } else {
      nodes = JSON.parse(data.data1);
      links = JSON.parse(data.data2);
    }

    console.log("ajax");
    console.log(nodes);//结点
    console.log(links);//边
  },
  error: function(jqXHR, textStatus, errorThrown) {
    console.log("errorThrown");
    console.log(errorThrown);
  }
});
console.log("nodes")
console.log(nodes)
nodeIds = nodes.map(node => node.id);
const adjacencyMatrix = new Array(nodeIds.length + 1).fill(0).map(() => new Array(nodeIds.length + 1).fill(0));

// 在 links 中查找每条边的源节点和目标节点，更新邻接矩阵
   links.forEach(link => {
        const sourceIndex = nodeIds.indexOf(link.source) + 1;
        const targetIndex = nodeIds.indexOf(link.target) + 1;
        if (sourceIndex !== -1 && targetIndex !== -1) {
            adjacencyMatrix[sourceIndex][targetIndex] = 1;
        }
});

const relationControlMenu = document.querySelector(".relation-control-menu");
const menuElem = document.querySelector(".menu.control-menu-list");
relationControlMenu.addEventListener("click", function () {
    // 在此处执行点击事件的操作
    if (menuElem.classList.contains("active")) {
        menuElem.classList.remove("active");
    } else {
        menuElem.classList.add("active");
    }
});

