                    return `M${sourceCoords.x},${sourceCoords.y}L${targetCoords.x},${targetCoords.y}`;
                });
                linkGroup3.attr("transform", d => {
                    const sourceCoords = nodeCoordinates[d.source.id];
                    const targetCoords = nodeCoordinates[d.target.id];

                    const dx = targetCoords.x - sourceCoords.x;
                    const dy = targetCoords.y - sourceCoords.y;
                    const x = (sourceCoords.x + targetCoords.x) / 2;
                    const y = (sourceCoords.y + targetCoords.y) / 2;
                    return `translate(${x},${y}) rotate(${Math.atan2(dy, dx) * 180 / Math.PI})`;
                });
                linkRect3.each(function (d) {
                    const bbox = this.getBBox();
                    const padding = 10;
                    const text = d3.select(this.parentNode).select(".link-text").node();
                    const textWidth = text ? text.getBBox().width : 0;
                    const textHeight = text ? text.getBBox().height : 0;
                    d3.select(this)
                        .attr("width", textWidth + padding)
                        .attr("height", bbox.height)
                        .attr("x", -textWidth / 2 - padding / 2)
                        .attr("y", -bbox.height / 2 + padding / 32);
                    if (text) {
                        d3.select(text)
                            .attr("x", -textWidth / 2)
                            .attr("y", textHeight / 64 + 2); // 调整文本的垂直位置为矩形框的64分之一处
                    }
                });
            }

            // 定义拖动行为
            function searchdrag3(searchSimulation3) {

                // 开始拖动
                function dragstarted(event) {
                    if (!event.active) searchSimulation3.alphaTarget(0.3).restart();
                    event.subject.fx = event.subject.x;
                    event.subject.fy = event.subject.y;

                }

                // 拖动中
                function dragged(event) {
                    event.subject.fx = event.x;
                    event.subject.fy = event.y;

                }

                // 结束拖动
                function dragended(event) {
                    if (!event.active) searchSimulation3.alphaTarget(0);
                    event.subject.fx = event.x;
                    event.subject.fy = event.y;

                }

                return d3.drag()
                    .on("start", dragstarted)
                    .on("drag", dragged)
                    .on("end", dragended);
            }
        }
