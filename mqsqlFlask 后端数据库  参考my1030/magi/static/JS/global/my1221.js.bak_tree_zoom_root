//根据邻接矩阵，查找两个结点的所有路径，接口是findPathsBetweenNodes
function findAllPaths(start, end, graph, visited, path, paths) {
    visited[start] = true;
    path.push(start);

    if (start === end) {
        paths.push([...path]);
    } else {
        for (let i = 0; i < graph[start].length; i++) {
            if (graph[start][i] === 1 && !visited[i]) {
                findAllPaths(i, end, graph, visited, path, paths);
            }
        }
    }

    path.pop();
    visited[start] = false;
}

function findPathsBetweenNodes(startNode, endNode, adjacencyMatrix) {
    const graph = adjacencyMatrix;
    const visited = new Array(graph.length).fill(false);
    const paths = [];
    const path = [];
    findAllPaths(startNode, endNode, graph, visited, path, paths);
    return paths;
}

